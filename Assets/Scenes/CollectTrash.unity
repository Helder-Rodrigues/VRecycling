  m_EditorClassIdentifier: Assembly-CSharp::GameTutorial
  guide: {fileID: 1597155056}
  grabVacuumTarget: {fileID: 1241573107}
  vacuumFullTarget: {fileID: 1241573108}
  pressButtonTarget: {fileID: 156857137}
  beginString: Welcome to the park! There is a lot of trash around and someone needs
    to tidy up. Use the joysticks to move around.
  grabVacuumString: There sure is a lot of mess! Grab the vacuum cleaner over by
    the fountain by pressing the triggers on your controller.
  vacuumTrashString: Now you can start collecting! To vacuum up the trash, press
    and hold both triggers on the same controller.
  vacuumFullString: The vacuum is full! You can keep an eye on the capacity using
    the status bar on the side of the device.
  pressButtonString: To empty the vacuum, head over to the table by the fountain
    and press the action button.
  sortTrashString: Now that the trash is on the table, it's time to finish the job.
    Sort the trash into the correct bins!
